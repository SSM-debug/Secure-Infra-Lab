# Flask environment variables
# This file is managed by Ansible — do not edit manually
# Permissions: 0600 (root only)

# Database connection
DB_HOST={{ database_ip }}
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASS={{ db_password }}

# Server identification
SERVER_NAME={{ server_name }}

# Flask port
FLASK_PORT={{ flask_port }}